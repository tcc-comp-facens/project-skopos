# Force LF line endings for shell scripts and Docker files
*.sh text eol=lf
Dockerfile text eol=lf
*.dockerfile text eol=lf
docker-compose*.yml text eol=lf
entrypoint.sh text eol=lf

# Keep Windows line endings for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Auto-detect for everything else
* text=auto
